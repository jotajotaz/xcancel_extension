{
  "manifest_version": 3,
  "name": "xcancel – Redirect X to xcancel",
  "version": "1.0.0",
  "description": "Automatically redirects x.com and twitter.com links to xcancel.com (except articles).",
  "permissions": [
    "declarativeNetRequest",
    "webNavigation"
  ],
  "host_permissions": [
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],
  "background": {
    "service_worker": "shared/background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "redirect_rules",
        "enabled": true,
        "path": "shared/rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shared/url-rewriter.js", "shared/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
