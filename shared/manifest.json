{
  "manifest_version": 3,
  "name": "xcancel – Redirect X to xcancel",
  "version": "1.0.0",
  "description": "Automatically redirects x.com and twitter.com links to xcancel.com (except articles).",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["url-rewriter.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
